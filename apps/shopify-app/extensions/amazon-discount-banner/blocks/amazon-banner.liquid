<script>
(function() {
  var APP_BASE_URL = '{{ block.settings.app_base_url | strip | escape }}';
  var TWINSTORE_BACKEND_URL = '{{ block.settings.twinstore_backend_url | strip | escape }}';
  var DEFAULT_DISCOUNT_CODE = '{{ block.settings.discount_code | default: "AMAZON5" | escape }}';
  var DELAY_MS = 5000;
  var SIGNUP_QUERY_KEY = "amz_discount";
  var USER_QUERY_KEY = "amz_external_user_id";
  var PRESET_POLL_ATTEMPTS = 20;
  var PRESET_POLL_INTERVAL_MS = 2000;

  // ---------- utilities ----------
  function normalizedBackendUrl() {
    var t = String(TWINSTORE_BACKEND_URL || "").trim();
    if (!t) return "";
    return t.replace(/\/$/, "");
  }
  // All Knot API calls (session create, accounts, discount) go directly to the
  // TwinStore backend. The Shopify app proxy (/apps/knot) requires a live
  // ngrok/tunnel URL configured in the Partners dashboard which isn't always
  // available in development — routing through the backend is simpler and
  // avoids the proxy entirely.
  function buildApiUrl(path) {
    return buildBackendUrl(path);
  }
  function buildBackendUrl(path) {
    var base = normalizedBackendUrl();
    if (!base) return "";
    return base + path;
  }
  function withUrlParam(url, key, value) {
    var u = new URL(url, window.location.origin);
    u.searchParams.set(key, value);
    return u.toString();
  }
  function removeUrlParams(keys) {
    var url = new URL(window.location.href);
    for (var i = 0; i < keys.length; i += 1) url.searchParams.delete(keys[i]);
    window.history.replaceState({}, "", url.toString());
  }
  function getShopDomain() {
    if (window.Shopify && window.Shopify.shop) return window.Shopify.shop;
    return window.location.hostname;
  }

  // ---------- preset application ----------
  var PRESET_STYLE_ID = "twinstore-preset-style";
  var PRESET_HERO_ID = "twinstore-preset-hero";
  var HIDDEN_HERO_CLASS = "twinstore-native-hero-hidden";

  function injectPresetCss(css) {
    var node = document.getElementById(PRESET_STYLE_ID);
    if (!node) {
      node = document.createElement("style");
      node.id = PRESET_STYLE_ID;
      document.head.appendChild(node);
    }
    var hideRule = "main .shopify-section:first-of-type, main > section:first-of-type, main > .section:first-of-type { display: none !important; }";
    node.textContent = (css || "") + "\n" + hideRule;
  }

  function injectPresetHtml(html) {
    if (!html) return false;
    var main = document.querySelector("main#MainContent") || document.querySelector("main") || document.body;
    if (!main) return false;
    var existing = document.getElementById(PRESET_HERO_ID);
    if (existing) existing.remove();
    var wrapper = document.createElement("div");
    wrapper.id = PRESET_HERO_ID;
    wrapper.innerHTML = html;
    main.insertBefore(wrapper, main.firstChild);
    return true;
  }

  function applyPreset(preset, source) {
    if (!preset) return false;
    var html = preset.generated_html || "";
    var css = preset.generated_css || "";
    if (!html && !css) {
      console.warn("[TwinStore] preset has no generated_html/css:", preset.id);
      return false;
    }
    injectPresetCss(css);
    injectPresetHtml(html);
    document.documentElement.setAttribute("data-twinstore-preset", preset.id || "unknown");
    console.log("[TwinStore] preset applied:", preset.display_name || preset.id, "via", source);
    return true;
  }

  async function fetchPresetForSession(externalUserId) {
    var endpoint = buildBackendUrl("/preset-for-session/" + encodeURIComponent(externalUserId));
    if (!endpoint) return null;
    try {
      var res = await fetch(endpoint + "?shop=" + encodeURIComponent(getShopDomain()), {
        method: "GET",
        headers: { "ngrok-skip-browser-warning": "1" },
      });
      if (!res.ok) return null;
      return await res.json();
    } catch (_) { return null; }
  }

  async function pollAndApplyPreset(externalUserId, onApplied) {
    for (var i = 0; i < PRESET_POLL_ATTEMPTS; i += 1) {
      var data = await fetchPresetForSession(externalUserId);
      if (data && data.preset) {
        var applied = applyPreset(data.preset, "session");
        if (applied && typeof onApplied === "function") onApplied(data);
        return data;
      }
      await new Promise(function(r) { setTimeout(r, PRESET_POLL_INTERVAL_MS); });
    }
    return null;
  }

  // ---------- styles + toast ----------
  var style = document.createElement("style");
  style.textContent = `
    .amz-popup { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
      position: fixed; bottom: 20px; right: 20px; width: 280px; max-width: calc(100vw - 40px);
      z-index: 2147483646;
      background: #fff;
      border-radius: 12px;
      border: 1px solid #e5e7eb;
      box-shadow: 0 8px 30px rgba(0,0,0,0.10), 0 2px 8px rgba(0,0,0,0.06);
      transform: translateY(12px); opacity: 0;
      transition: transform 0.35s cubic-bezier(0.34, 1.4, 0.64, 1), opacity 0.25s ease; }
    .amz-popup.is-visible { transform: translateY(0); opacity: 1; }
    .amz-popup__close { position: absolute; top: 10px; right: 10px; width: 20px; height: 20px; border-radius: 50%;
      background: none; border: none; color: #9ca3af;
      font-size: 16px; line-height: 1; display: flex; align-items: center; justify-content: center;
      cursor: pointer; transition: color 0.15s ease; z-index: 2; padding: 0; }
    .amz-popup__close:hover { color: #374151; }
    .amz-popup__body { padding: 18px 18px 16px; }
    .amz-popup__eyebrow { margin: 0 0 8px; font-size: 10px; font-weight: 600; letter-spacing: 0.1em;
      text-transform: uppercase; color: #FF9900; }
    .amz-popup__title { margin: 0 0 14px; font-size: 15px; font-weight: 600; color: #111827;
      letter-spacing: -0.01em; line-height: 1.35; padding-right: 16px; }
    .amz-popup__benefits { margin: 0 0 16px; padding: 0; list-style: none; display: flex; flex-direction: column; gap: 7px; }
    .amz-popup__benefits li { display: flex; align-items: center; gap: 8px;
      font-size: 12px; color: #6b7280; line-height: 1.4; }
    .amz-popup__benefits li svg { flex-shrink: 0; color: #10b981; }
    .amz-popup__cta { display: inline-flex; align-items: center; justify-content: center; gap: 7px; width: 100%;
      background: #111827; color: #fff; border: none; border-radius: 8px;
      padding: 11px 14px; font-family: inherit; font-size: 13px; font-weight: 600; cursor: pointer;
      transition: background 0.15s ease; letter-spacing: 0.01em; }
    .amz-popup__cta:hover { background: #1f2937; }
    .amz-popup__cta-amazon { color: #FF9900; font-weight: 700; }
    .amz-popup__note { margin: 10px 0 0; text-align: center; font-size: 10px; color: #d1d5db; }
    .amz-toast { position: fixed; bottom: 18px; right: 18px; max-width: min(92vw, 420px); z-index: 2147483647;
      padding: 14px 16px; border-radius: 12px; border: 1px solid rgba(255,153,0,0.3);
      background: linear-gradient(135deg, rgba(35,47,62,0.97), rgba(18,28,40,0.97)); color: #fff;
      box-shadow: 0 12px 28px rgba(0,0,0,0.35); font-family: "Inter", -apple-system, BlinkMacSystemFont, sans-serif; font-size: 14px; line-height: 1.4; }
    .amz-toast strong { color: #FFB347; font-size: 16px; }
    .amz-toast--error { border-color: rgba(255,110,110,0.35); }
    .amz-signout { position: fixed; bottom: 14px; left: 14px; z-index: 2147483645;
      font-family: "Inter", -apple-system, BlinkMacSystemFont, sans-serif;
      font-size: 10px; color: rgba(0,0,0,0.3); background: none; border: none;
      cursor: pointer; padding: 4px 6px; border-radius: 4px; letter-spacing: 0.02em;
      transition: color 0.2s ease, background 0.2s ease; }
    .amz-signout:hover { color: rgba(0,0,0,0.6); background: rgba(0,0,0,0.06); }
  `;
  document.head.appendChild(style);

  function showToast(html, isError) {
    var node = document.createElement("div");
    node.className = "amz-toast" + (isError ? " amz-toast--error" : "");
    node.innerHTML = html;
    document.body.appendChild(node);
    setTimeout(function() { node.remove(); }, 9000);
  }

  // ---------- Knot SDK loader + discount helpers ----------
  function loadKnotSdk() {
    if (window.KnotapiJS && window.KnotapiJS.default) return Promise.resolve();
    return new Promise(function(resolve, reject) {
      var script = document.createElement("script");
      script.src = "https://unpkg.com/knotapi-js@next";
      script.async = true;
      script.onload = function() { resolve(); };
      script.onerror = function() { reject(new Error("Failed to load Knot SDK")); };
      document.head.appendChild(script);
    });
  }

  async function verifyKnotAccount(externalUserId) {
    if (!externalUserId) return null;
    var endpoint = buildApiUrl("/api/knot/accounts?externalUserId=" + encodeURIComponent(externalUserId) + "&merchantName=Amazon");
    if (!endpoint) return null;
    var r = await fetch(endpoint, { method: "GET" });
    if (!r.ok) return null;
    return r.json();
  }

  async function fetchWebhookDiscountCode(externalUserId) {
    if (!externalUserId) return null;
    var endpoint = buildApiUrl("/api/knot/discount?externalUserId=" + encodeURIComponent(externalUserId));
    if (!endpoint) return null;
    var r = await fetch(endpoint, { method: "GET" });
    if (!r.ok) return null;
    var data = await r.json();
    return data && data.discountCode ? data.discountCode : null;
  }

  async function waitForWebhookDiscountCode(externalUserId) {
    for (var i = 0; i < 5; i += 1) {
      var code = await fetchWebhookDiscountCode(externalUserId);
      if (code) return code;
      await new Promise(function(r) { setTimeout(r, 1800); });
    }
    return null;
  }

  var DASHBOARD_URL = "{{ block.settings.dashboard_url | default: 'http://localhost:4000' | strip | escape }}";

  function showSuccessMessage(discountCode, presetName, externalUserId) {
    var presetLine = presetName ? "<br><span>Your storefront just morphed to <strong>" + presetName + "</strong>.</span>" : "";
    var profileLink = "";
    if (externalUserId && DASHBOARD_URL) {
      var profileUrl = DASHBOARD_URL.replace(/\/$/, "") + "/shopper/" + encodeURIComponent(externalUserId);
      profileLink = "<br><a href=\"" + profileUrl + "\" target=\"_blank\" rel=\"noopener\" style=\"color:#FFB347;text-decoration:underline;font-size:12px;\">View your twin profile →</a>";
    }
    showToast("You're in. 5% code: <strong>" + discountCode + "</strong>" + presetLine + profileLink, false);
  }

  // ---------- PAGE LOAD: apply preset if twin already exists ----------
  var savedExternalUserId = localStorage.getItem("amz_external_user_id");
  if (savedExternalUserId) {
    fetchPresetForSession(savedExternalUserId).then(function(data) {
      if (data && data.preset) applyPreset(data.preset, "cached-session");
    });
    // Sign-out button — bottom-left, only visible when linked
    var signoutBtn = document.createElement("button");
    signoutBtn.className = "amz-signout";
    signoutBtn.textContent = "Unlink Amazon";
    signoutBtn.addEventListener("click", function() {
      localStorage.removeItem("amz_external_user_id");
      localStorage.removeItem("amz_discount_code");
      window.location.reload();
    });
    document.body.appendChild(signoutBtn);
  }

  // ---------- RETURN-FROM-SIGNUP: poll backend, apply, show discount ----------
  var urlParams = new URL(window.location.href).searchParams;
  var signupFlag = urlParams.get(SIGNUP_QUERY_KEY);
  var returnExternalUserId = urlParams.get(USER_QUERY_KEY);
  var savedDiscountCode = localStorage.getItem("amz_discount_code");

  if (signupFlag === "1") {
    var userForFlow = returnExternalUserId || savedExternalUserId;
    if (userForFlow) {
      localStorage.setItem("amz_external_user_id", userForFlow);
      Promise.all([
        waitForWebhookDiscountCode(userForFlow),
        verifyKnotAccount(userForFlow).catch(function() { return null; }),
        pollAndApplyPreset(userForFlow),
      ]).then(function(results) {
        var issuedCode = results[0];
        var presetData = results[2];
        var codeToShow = issuedCode || savedDiscountCode || DEFAULT_DISCOUNT_CODE;
        localStorage.setItem("amz_discount_code", codeToShow);
        var presetName = presetData && presetData.preset ? presetData.preset.display_name : null;
        showSuccessMessage(codeToShow, presetName, userForFlow);
      });
    } else {
      showSuccessMessage(savedDiscountCode || DEFAULT_DISCOUNT_CODE, null, savedExternalUserId);
    }
    removeUrlParams([SIGNUP_QUERY_KEY, USER_QUERY_KEY, "merchant"]);
    return; // popup not needed — user just linked
  }

  // ---------- SIGNUP POPUP (only shown if not already linked) ----------
  if (savedExternalUserId) return; // already linked — no popup needed
  var popup = document.createElement("div");
  popup.className = "amz-popup";
  popup.innerHTML = `
    <button class="amz-popup__close" aria-label="Close">&times;</button>
    <div class="amz-popup__body">
      <p class="amz-popup__eyebrow">Exclusive offer</p>
      <h2 class="amz-popup__title">Get 5% off &amp; a storefront built for you</h2>
      <ul class="amz-popup__benefits">
        <li>
          <svg width="13" height="13" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="8" fill="#d1fae5"/><path d="M4.5 8l2.5 2.5 4.5-5" stroke="#10b981" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          5% off your first order
        </li>
        <li>
          <svg width="13" height="13" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="8" fill="#d1fae5"/><path d="M4.5 8l2.5 2.5 4.5-5" stroke="#10b981" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          Homepage tuned to your taste
        </li>
        <li>
          <svg width="13" height="13" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="8" fill="#d1fae5"/><path d="M4.5 8l2.5 2.5 4.5-5" stroke="#10b981" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          One tap — no card needed
        </li>
      </ul>
      <button class="amz-popup__cta">
        Connect <span class="amz-popup__cta-amazon">Amazon</span>
      </button>
      <p class="amz-popup__note">We only read purchase history · Never post or charge</p>
    </div>
  `;
  document.body.appendChild(popup);

  setTimeout(function() { popup.classList.add("is-visible"); }, 400);

  function closePopup() {
    popup.classList.remove("is-visible");
    setTimeout(function() { popup.remove(); }, 400);
  }

  popup.querySelector(".amz-popup__close").addEventListener("click", closePopup);

  var cta = popup.querySelector(".amz-popup__cta");
  cta.addEventListener("click", async function(e) {
    e.preventDefault();
    try {
      cta.disabled = true;
      cta.style.opacity = "0.75";
      cta.textContent = "Opening Amazon\u2026";

      console.log("[TwinStore] CTA clicked — starting Knot flow");
      console.log("[TwinStore] backend URL:", TWINSTORE_BACKEND_URL || "(not set)");
      console.log("[TwinStore] shop domain:", getShopDomain());

      await loadKnotSdk();
      console.log("[TwinStore] Knot SDK loaded");

      var cleanUrl = window.location.origin + window.location.pathname + window.location.hash;
      var returnUrl = withUrlParam(cleanUrl, SIGNUP_QUERY_KEY, "1");
      var sessionEndpoint = buildApiUrl("/api/knot/session");
      if (!sessionEndpoint) {
        throw new Error("TwinStore backend URL is not configured. Set 'TwinStore Backend URL' in the theme block settings.");
      }
      var requestBody = { shopDomain: getShopDomain(), returnUrl: returnUrl };

      console.log("[TwinStore] POST", sessionEndpoint, "body:", requestBody);

      var sessionResponse;
      try {
        sessionResponse = await fetch(sessionEndpoint, {
          method: "POST",
          headers: { "Content-Type": "application/json", "Accept": "application/json" },
          body: JSON.stringify(requestBody),
        });
      } catch (netErr) {
        console.error("[TwinStore] Network error calling session endpoint:", netErr);
        throw new Error("Network error: " + (netErr && netErr.message ? netErr.message : "fetch failed") + " (endpoint: " + sessionEndpoint + ")");
      }

      console.log("[TwinStore] session response status:", sessionResponse.status, sessionResponse.statusText);
      console.log("[TwinStore] session response content-type:", sessionResponse.headers.get("content-type"));

      var contentType = sessionResponse.headers.get("content-type") || "";
      var rawText = "";
      try { rawText = await sessionResponse.text(); } catch (_) {}
      console.log("[TwinStore] session response raw body:", rawText.slice(0, 1000));

      var parsed = null;
      if (contentType.indexOf("application/json") !== -1) {
        try { parsed = JSON.parse(rawText); } catch (_) {}
      }

      if (!sessionResponse.ok) {
        var msg = (parsed && (parsed.details || parsed.error)) || rawText.slice(0, 300);
        if (!msg) msg = "HTTP " + sessionResponse.status;
        if (parsed && parsed.runtime) {
          console.error("[TwinStore] server runtime config:", parsed.runtime);
          msg += " [hasClientId=" + parsed.runtime.hasClientId + ", hasSecret=" + parsed.runtime.hasSecret + "]";
        }
        throw new Error(msg);
      }

      if (!parsed) {
        throw new Error("Server returned 200 but body was not JSON (content-type: " + contentType + "). First 200 chars: " + rawText.slice(0, 200));
      }

      var sessionData = parsed;
      console.log("[TwinStore] session created:", sessionData);
      var KnotapiJS = window.KnotapiJS.default;
      var knotapi = new KnotapiJS();

      knotapi.open({
        sessionId: sessionData.sessionId,
        clientId: sessionData.clientId,
        environment: sessionData.environment,
        merchantIds: sessionData.merchantIds,
        entryPoint: "storefront_amazon_popup",
        onSuccess: function(details) {
          var redirectUrl = sessionData.returnUrl || returnUrl;
          localStorage.setItem("amz_external_user_id", sessionData.externalUserId);
          window.location.href = withUrlParam(
            withUrlParam(redirectUrl, USER_QUERY_KEY, sessionData.externalUserId),
            "merchant",
            (details && details.merchantName) || "Amazon"
          );
        },
        onError: function(code, message) {
          cta.disabled = false; cta.style.opacity = ""; cta.textContent = "Link Amazon";
          showToast("Knot error (" + code + "): " + message, true);
        },
        onExit: function() {
          cta.disabled = false; cta.style.opacity = ""; cta.textContent = "Link Amazon";
        },
      });
    } catch (error) {
      cta.disabled = false; cta.style.opacity = ""; cta.textContent = "Link Amazon";
      var m = (error && error.message) ? error.message : "Unknown error";
      showToast("Unable to launch Amazon signup: " + m, true);
      console.error("[Amazon Popup] Knot launch failed", error);
    }
  });
})();
</script>

{% schema %}
{
  "name": "TwinStore Personalizer",
  "target": "body",
  "settings": [
    {
      "type": "text",
      "id": "app_base_url",
      "label": "Shopify App Proxy URL",
      "default": "/apps/knot",
      "info": "Used for Knot session + discount code endpoints. Leave as /apps/knot."
    },
    {
      "type": "text",
      "id": "twinstore_backend_url",
      "label": "TwinStore Backend URL",
      "default": "https://dbca-66-180-180-1.ngrok-free.app",
      "info": "Full URL of the FastAPI backend. Required for storefront personalization."
    },
    {
      "type": "text",
      "id": "discount_code",
      "label": "Fallback Discount Code",
      "default": "AMAZON5"
    },
    {
      "type": "text",
      "id": "dashboard_url",
      "label": "TwinStore Dashboard URL",
      "default": "http://localhost:4000",
      "info": "URL of the merchant dashboard. Used to link shoppers to their twin profile page."
    }
  ]
}
{% endschema %}
