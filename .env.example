# --- KnotAPI (TransactionLink) ---
# Get from https://customer.knotapi.com → Developer settings
KNOT_CLIENT_ID=
KNOT_SECRET=
KNOT_ENVIRONMENT=development
KNOT_WEBHOOK_SECRET=

# --- K2 Think V2 (MBZUAI / IFM) ---
# OpenAI-compatible endpoint expected
K2_API_KEY=
K2_BASE_URL=
K2_MODEL=k2-think-v2

# --- Supabase ---
# Get from https://supabase.com → Project settings → API
# Backend needs the SECRET key (formerly service_role). Never ship to the browser.
SUPABASE_URL=
SUPABASE_SECRET_KEY=
# Browser-safe — used if the dashboard queries Supabase directly (currently it doesn't)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# --- Shopify ---
# Partners app (https://partners.shopify.com → Apps → your app → API credentials)
# Used by Shopify CLI to run the Theme App Extension.
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=

# Dev store admin access (Settings → Apps and sales channels → Develop apps → Create + Install custom app)
# SHOP is the *.myshopify.com handle (no protocol)
# ADMIN_TOKEN is the shpat_... string from the custom app's API credentials tab
SHOPIFY_SHOP=
SHOPIFY_ADMIN_TOKEN=

# --- Dedalus ---
DEDALUS_API_KEY=
DEDALUS_IMAGE=twinstore-swarm-runner:latest

# --- Backend ---
# Public URL the swarm runner / Knot webhooks call back into.
# Use an ngrok URL during local dev.
BACKEND_PUBLIC_URL=http://localhost:8000

# --- Dashboard ---
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000
